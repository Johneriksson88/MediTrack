{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2022"],
    // `@meditrack/shared` contains no node-specific code — purely Zod schemas
    // + literal-union constants consumed by both browser (apps/web) and
    // server (apps/api). Pulling in `@types/node` here previously broke
    // `pnpm --filter @meditrack/shared build` (the package doesn't depend
    // on @types/node and shouldn't need to). Plan 03 deferred-items #1.
    "types": [],
    // Emit `.d.ts` files so consumers (apps/api, apps/web) get the inferred
    // Zod types via the package.json `types: ./dist/index.d.ts` field. The
    // base config defaults `declaration: false`; shared overrides because
    // it is the single source of truth for cross-package types (D-08).
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src"],
  // Phase 10 — vitest test files live alongside source under src/utils/__tests__
  // but vitest is NOT a build dependency of @meditrack/shared (run via the
  // workspace-installed binary). Excluding them keeps `tsc -p .` clean.
  "exclude": ["src/**/__tests__/**", "src/**/*.test.ts", "dist"]
}
