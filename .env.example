# Database connection (used by Prisma)
DATABASE_URL=postgres://meditrack:meditrack@localhost:5432/meditrack

# Cookie signing secret — MUST be at least 32 random bytes in production.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
COOKIE_SECRET=replace-me-with-32-bytes-random

# API server config
PORT=3000
NODE_ENV=development
