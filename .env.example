# Database connection (used by Prisma PrismaClient at runtime).
# Plan 05-07: runtime queries connect as the named non-owner role meditrack_app
# (REVOKE on AuditEvent UPDATE/DELETE/TRUNCATE binds this role — D-98 Layer 2b).
DATABASE_URL=postgres://meditrack_app:meditrack_app_dev@localhost:5432/meditrack

# Direct connection for prisma migrate deploy, prisma db seed, prisma studio.
# Uses the owner role (meditrack) which has full privileges needed to create
# roles, alter privileges, and run DDL migrations.
DIRECT_URL=postgres://meditrack:meditrack@localhost:5432/meditrack

# Cookie signing secret — MUST be at least 32 random bytes in production.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
COOKIE_SECRET=replace-me-with-32-bytes-random

# API server config
PORT=3000
NODE_ENV=development
