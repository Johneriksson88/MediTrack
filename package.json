{
  "name": "meditrack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint . --ext .ts,.tsx,.cts,.cjs --max-warnings=0",
    "lint:api": "eslint apps/api/src --ext .ts",
    "lint:web": "eslint apps/web/src --ext .ts,.tsx",
    "db:migrate": "pnpm --filter @meditrack/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @meditrack/api exec prisma db seed"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2"
  }
}
