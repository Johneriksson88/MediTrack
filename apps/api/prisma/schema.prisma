// MediTrack — Phase 1 schema (Pattern A, D-01, D-07, AUTH-04, AUTH-07)
//
// User → CareUnit:    one user belongs to exactly one vårdenhet (AUTH-07).
// Session → User:     opaque-ID server-side sessions (D-01); `careUnitId`
//                     snapshot lives on Session so the auth preHandler can
//                     decorate `req.user.careUnitId` without joining User
//                     on every request (D-16, performance + audit safety).
//
// Phase 2 additions (D-27, D-28, D-33):
//
// Medication:         Global NPL registry — one row per drug (~43 538 rows
//                     from Läkemedelsverket seed). No careUnitId here;
//                     NPL is the canonical catalog (D-27).
// CareUnitMedication: Per-vårdenhet join carrying currentStock +
//                     lowStockThreshold + soft-delete flag (D-28, D-33).
//                     @@unique([careUnitId, medicationId]) prevents duplicate
//                     active rows; transparent restore via UPDATE deletedAt=NULL
//                     instead of INSERT (D-30).
//
// Phase 3 additions (D-46..D-48, D-62, D-63):
//
// OrderStatus:        Postgres enum mirroring ORDER_STATUSES in
//                     packages/shared/src/constants/orderStatus.ts (D-46).
//                     All four values declared here; Phase 3 only uses
//                     utkast + skickad; Phase 4 uses bekraftad + levererad.
// Order:              careUnitId-scoped order with soft-delete (D-48, D-62).
//                     Single table — status column distinguishes lifecycle.
// OrderLine:          Per-medication line referencing CareUnitMedication (D-63).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  apotekare
  sjukskoterska
  admin
}

/// Phase 2 D-27 — MedicationSource discriminates NPL-seeded rows from
/// user-created rows ('Skapa nytt läkemedel' fallback, D-31).
/// NPL-sourced rows have locked name/atcCode/form/strength (D-32).
enum MedicationSource {
  npl
  user
}

model CareUnit {
  id                  String               @id @default(cuid())
  name                String
  createdAt           DateTime             @default(now())
  users               User[]
  careUnitMedications CareUnitMedication[]
  orders              Order[]
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         Role
  careUnitId   String
  careUnit     CareUnit  @relation(fields: [careUnitId], references: [id])
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  /// Phase 3 D-62 — back-relations for orders created / submitted by this user.
  createdOrders   Order[] @relation("OrderCreatedBy")
  submittedOrders Order[] @relation("OrderSubmittedBy")

  /// Phase 4 D-84 — back-relations for orders confirmed / delivered by this user.
  confirmedOrders Order[] @relation("OrderConfirmedBy")
  deliveredOrders Order[] @relation("OrderDeliveredBy")

  @@index([careUnitId])
}

model Session {
  // Session ID is set by the app (crypto.randomBytes(32) base64url, NOT cuid).
  id         String   @id
  userId     String
  // Denormalized snapshot of the user's careUnit at session creation (D-16).
  careUnitId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Phase 2 D-27 — Global NPL registry. One row per drug; ~43 538 rows from
/// Läkemedelsverket seed. No careUnitId — per-vårdenhet stock+threshold
/// lives on CareUnitMedication. form is String (not enum) — the NPL catalog
/// has 500+ distinct form values; String avoids a migration on every new form.
model Medication {
  id                  String               @id @default(cuid())
  /// Unique NPL identifier; null for user-created drugs (D-31).
  nplId               String?              @unique
  name                String
  atcCode             String
  form                String
  strength            String?
  source              MedicationSource
  /// Phase 6 D-113 / D-114 / D-115 — therapeutic class (closed enum of the
  /// 14 WHO ATC level-1 anatomical groups). Nullable because the 43k NPL
  /// seed rows start unset (no seed-time backfill — see PROJECT.md /
  /// 06-CONTEXT.md "What I'm least proud of"); user-created meds start
  /// null until "Hämta AI-förslag" → "Använd förslag" populates the field.
  /// Editable on NPL meds per D-32 carve-out documented in D-115
  /// (classification is metadata, not pharmaceutical identity).
  therapeuticClass    TherapeuticClass?
  createdAt           DateTime             @default(now())
  careUnitMedications CareUnitMedication[]

  @@index([atcCode])
  /// Phase 6 D-117 — single-column index supports the AI-03 filter combobox
  /// on /lakemedel and any future dashboard JOIN over the class column.
  @@index([therapeuticClass])
}

/// Phase 2 D-28 — Per-vårdenhet join table. Carries currentStock,
/// lowStockThreshold, and a soft-delete flag (D-33: always soft-delete;
/// global Medication is never deleted). @@unique([careUnitId, medicationId])
/// is the database guard against duplicate active rows (T-02-06).
/// Phase 4 adds SELECT … FOR UPDATE on the stock-decrement path (STK-02).
model CareUnitMedication {
  id String @id @default(cuid())

  careUnitId String
  careUnit   CareUnit @relation(fields: [careUnitId], references: [id])

  medicationId String
  medication   Medication @relation(fields: [medicationId], references: [id])

  currentStock      Int
  lowStockThreshold Int

  /// CAT-07 / D-33 — soft-delete flag. SET deletedAt = now() on delete;
  /// never hard-delete. Read queries always filter deletedAt: null.
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Phase 3 D-63 — back-relation for order lines referencing this med.
  orderLines OrderLine[]

  @@unique([careUnitId, medicationId])
  @@index([careUnitId])
  @@index([deletedAt])
}

// ---------------------------------------------------------------------------
// Phase 3 — Order flow (D-46..D-48, D-62, D-63)
// ---------------------------------------------------------------------------

/// Phase 3 D-46 — OrderStatus mirrors ORDER_STATUSES from
/// packages/shared/src/constants/orderStatus.ts verbatim (single source of
/// truth for the closed status set). All four values declared here even though
/// Phase 3 only uses utkast + skickad — Phase 4 needs zero schema work to
/// introduce bekraftad / levererad.
enum OrderStatus {
  utkast
  skickad
  bekraftad
  levererad
}

/// Phase 6 D-113 / D-114 — Therapeutic class enum mirrors THERAPEUTIC_CLASSES
/// in packages/shared/src/constants/therapeuticClass.ts verbatim. The 14
/// WHO ATC level-1 anatomical groups: A, B, C, D, G, H, J, L, M, N, P, R,
/// S, V. The Postgres enum literals (created via CREATE TYPE in migration
/// 0012) match these values exactly — Prisma generates the matching SQL.
enum TherapeuticClass {
  A
  B
  C
  D
  G
  H
  J
  L
  M
  N
  P
  R
  S
  V
}

/// Phase 3 D-48 / D-62 — Single Order table; status column distinguishes
/// draft from submitted. careUnitId-scoped; soft-delete via deletedAt (D-62 / D-33
/// carry-over from CareUnitMedication). Dual FKs to User need @relation(name:…)
/// to disambiguate createdBy vs submittedBy (Prisma requirement).
///
/// Indexes: (careUnitId, status) powers GET /api/orders?status=utkast;
///          (careUnitId, createdAt) powers sort; (createdByUserId) for future
///          "my drafts" filter.
///
/// Phase 4 adds confirm/deliver transitions (ORD-04, ORD-05); the
/// submittedAt/By column-pair establishes the confirmedAt/By + deliveredAt/By
/// precedent Phase 4 mirrors.
model Order {
  id String @id @default(cuid())

  careUnitId String
  careUnit   CareUnit @relation(fields: [careUnitId], references: [id])

  /// Draft author; Restrict prevents deleting a user who has authored orders.
  createdByUserId String
  createdBy       User   @relation(name: "OrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  status OrderStatus @default(utkast)

  /// D-49 — stamped by the submit transition; null while in utkast.
  submittedAt DateTime?

  /// D-49 — FK to the user who submitted; Restrict prevents deleting a user
  /// with historical Skickad orders. Named relation required by Prisma to
  /// disambiguate from createdBy (two FKs to User on the same model).
  submittedByUserId String?
  submittedBy       User?   @relation(name: "OrderSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: Restrict)

  /// Phase 4 D-84 — stamped by the confirm transition; null while in utkast/skickad.
  confirmedAt DateTime?

  /// Phase 4 D-84 — FK to the user who confirmed; Restrict preserves history.
  /// Named relation disambiguates from createdBy/submittedBy/deliveredBy.
  confirmedByUserId String?
  confirmedBy       User?   @relation(name: "OrderConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: Restrict)

  /// Phase 4 D-84 — stamped by the deliver transition; null until levererad.
  deliveredAt DateTime?

  /// Phase 4 D-84 — FK to the user who delivered; Restrict preserves history.
  deliveredByUserId String?
  deliveredBy       User?   @relation(name: "OrderDeliveredBy", fields: [deliveredByUserId], references: [id], onDelete: Restrict)

  /// D-62 / D-33 — soft-delete flag for the Discard affordance (D-67).
  /// Lists always filter deletedAt: null.
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines OrderLine[]

  @@index([careUnitId, status])
  @@index([careUnitId, createdAt])
  @@index([createdByUserId])
}

/// Phase 3 D-63 — Per-medication line on an order. onDelete: Cascade so
/// lines are removed when the parent order is hard-deleted (soft-delete on
/// Order is the normal path — hard-delete is DB maintenance only).
/// onDelete: Restrict on careUnitMedicationId preserves order history if a
/// medication is removed from the catalog.
///
/// No @@unique([orderId, careUnitMedicationId]) per D-63 — same med allowed
/// on two lines in v1 (merge-duplicates UI is a Phase 7 README note candidate).
///
/// Phase 4 reuses @@index([careUnitMedicationId]) for SELECT … FOR UPDATE on
/// the stock-lock path (STK-02).
model OrderLine {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  careUnitMedicationId String
  careUnitMedication   CareUnitMedication @relation(fields: [careUnitMedicationId], references: [id], onDelete: Restrict)

  /// Positive integer validated at the Zod boundary (D-63) AND enforced by a
  /// DB-level CHECK constraint added in migration 0005 (WR-01 fix). The
  /// orderLineResponse contract asserts positive(); the check keeps the row
  /// shape drift-proof against direct writes that bypass the route layer.
  quantity Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([careUnitMedicationId])
}

// ---------------------------------------------------------------------------
// Phase 5 — Audit log (AUD-01, D-90..D-105)
// ---------------------------------------------------------------------------

/// Phase 5 D-97 / D-98 — Append-only audit table for every Phase 2/3/4
/// mutation. Populated by the Prisma `$extends` middleware in
/// `apps/api/src/db/auditExtension.ts` inside the same transaction as the
/// wrapping mutation (D-91); rolled-back mutations leave zero audit rows.
///
/// NO foreign key on `actorUserId` (deliberate — D-97). The audit log must
/// survive User row deletion for forensics; with a FK, deleting a User
/// would either cascade-corrupt history or block the delete entirely.
/// The field is a bare String? so the row stays referentially loose.
/// The denormalized `careUnitId` plays the same role for tenant scoping
/// in a future per-vårdenhet admin view.
///
/// `before` and `after` store FULL row snapshots filtered through the
/// per-model allowlist in `apps/api/src/db/auditAllowlist.ts` (D-97 —
/// User.passwordHash and Session.id are excluded). Diff is computed at
/// READ time inside AuditDiffPanel (D-95).
///
/// `entityId` for Session-typed audit rows MUST carry the actor User.id,
/// NEVER Session.id (which IS the raw signed session token). The
/// branching lives in `resolveEntityId(model, row)` (D-97 + T-05-03).
///
/// Append-only enforcement: the follow-on migration 0008 REVOKEs
/// UPDATE/DELETE/TRUNCATE on this table from the DB role embedded in
/// DATABASE_URL (D-98 layer 2). Combined with an ESLint
/// `no-restricted-syntax` rule banning `prisma.auditEvent.update/delete/
/// updateMany/deleteMany/upsert` (D-99 — Plan 03, layer 1), append-only
/// is enforced both in the code and at the role level.
///
/// Indexes (D-CONTEXT.md `<domain>` line 13):
///   (createdAt DESC, id)         — cursor pagination key (D-105)
///   (actorUserId, createdAt DESC) — actor combobox filter (D-103)
///   (entityType, createdAt DESC)  — entity-type filter (D-103)
///   (action, createdAt DESC)      — action filter (D-103)
///   (requestId)                   — sibling-event grouping (D-94)
model AuditEvent {
  id String @id @default(cuid())

  /// D-97 — nullable for auth.login_failed where no User has authenticated.
  /// No @relation: deleting a User must not cascade-corrupt the audit log.
  actorUserId String?

  /// D-97 — denormalized careUnit scope (nullable for session/user/auth
  /// events that aren't naturally vårdenhet-scoped). Enables a future v2
  /// per-vårdenhet admin view (§6 "50 vårdenheter" answer).
  careUnitId String?

  /// D-97 — open string enum: medication | care_unit_medication | order |
  /// order_line | user | session (extensible per D-104 footer). The shared
  /// AUDIT_ENTITY_TYPES list is the FE label-map source of truth.
  entityType String

  /// D-97 + T-05-03 — natural PK for the audited row, EXCEPT for Session
  /// where this column carries the actor User.id (NEVER row.id, which is
  /// the raw signed session token). Branching centralized in
  /// resolveEntityId(model, row) in auditAllowlist.ts.
  entityId String

  /// D-104 — open string set. Defaults to the Prisma method name
  /// (create/update/delete) but can be overridden via the ALS
  /// actionOverride field (D-94 — order.submit/order.confirm/
  /// order.deliver/stock.increment/auth.login/auth.logout/
  /// auth.login_failed).
  action String

  /// D-95 — full pre-mutation row snapshot, filtered through
  /// AUDIT_ALLOWLIST[model]. Null for create events.
  before Json?

  /// D-95 — full post-mutation row snapshot, filtered through
  /// AUDIT_ALLOWLIST[model]. Null for delete events.
  after Json?

  /// D-94 — sibling events share a requestId. Sourced from the
  /// AsyncLocalStorage store seeded in requestContext.ts; null for
  /// non-HTTP-originated writes (auth.login_failed before ALS exists,
  /// or any future cron path that opts in to audit without a request).
  requestId String?

  /// Claude's discretion (CONTEXT.md `<decisions>` line 105) — cheap
  /// signal for §6 anti-abuse discussion. Populated from
  /// req.headers['x-forwarded-for'] / req.ip in the requestContext
  /// plugin. Null for non-HTTP writes.
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc), id])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([entityType, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([requestId])
}
